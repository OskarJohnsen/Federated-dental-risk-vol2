  "age_rules": {
    "Age_Scaling": {
      "description": "Age factor: (age - 25) / 10.0, max 2.0",
      "effects": {"4": 0.10}
    }
  },
  "ian_proximity_rules": {
    "Close_IAN": {
      "conditions": {"Proximity_Nerve": [1]},
      "effects": {"3": 1.00, "4": -0.40}
    },
    "Deep_IAN_Close": {
      "conditions": {"Impaction_Depth": [3], "Proximity_Nerve": [1]},
      "effects": {"3": 1.00, "2": -0.30, "4": -0.30}
    },
    "Partial_IAN_Close": {
      "conditions": {"Impaction_Depth": [2], "Proximity_Nerve": [1]},
      "effects": {"3": 0.50}
    },
    "Mechanical_Difficulty_No_IAN": {
      "conditions": {"Proximity_Nerve": [0], "Tooth_Angulation": [4]},
      "additional_conditions": {"Root_Count": [">=3"], "Root_Curvature": [1]},
      "effects": {"4": 0.60, "2": 0.20}
    }
  },
  "symptom_interactions": {
    "Swelling_Trismus_IAN_Close": {
      "conditions": {"Swelling": [1], "Trismus": [1], "Proximity_Nerve": [1]},
      "effects": {"3": 0.30, "2": 0.10}
