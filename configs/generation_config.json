{
  "description": "Configuration for synthetic dataset generation parameters",
  
  "dataset": {
    "n_clients": 10,
    "patients_per_client": 10000,
    "random_seed": 42,
    "version": "1.0",
    "description": "Total dataset size = n_clients × patients_per_client"
  },
  
  "client_profiles": {
    "n_profiles": 10,
    "seed": 42,
    "ranges": {
      "age_mu": {"min": 20, "max": 40},
      "proximity_nerve_p": {"min": 0.15, "max": 0.60},
      "score_scale": {"min": 0.70, "max": 1.30},
      "missingness_rate": {"min": 0.0, "max": 0.25},
      "measurement_noise": {"min": 0.03, "max": 0.15},
      "max_missingness_columns": 3
    }
  },
  
  "decision_model": {
    "temperature": 1.0,
    "noise_sd": 0.1,
    "description": "Softmax temperature controls decision randomness. noise_sd adds Gaussian noise to scores before softmax."
  },
  
  "output": {
    "formats": ["csv", "xlsx"],
    "output_dir": "../../data/raw/",
    "filename_base": "placeholder",
    "description": "Output files: fed_recommenders_synthetic_dataset.csv and .xlsx"
  },
  
  "metadata": {
    "target_variables": {
      "classifcation": [
        {
          "name": "Risk_AlveolarOsteitis",
          "type": "binary",
          "n_classes": 2,
          "labels": ["No", "Yes"]
        },
        {
          "name": "Risk_SecondaryInfection",
          "type": "binary",
          "n_classes": 2,
          "labels": ["No", "Yes"]
        },
        {
          "name": "Risk_NerveDysesthesia",
          "type": "binary",
          "n_classes": 2,
          "labels": ["No", "Yes"]
        },
        {
          "name": "Risk_Bleeding",
          "type": "binary",
          "n_classes": 2,
          "labels": ["No", "Yes"]
        }
      ]
    },
    "n_features": 26,
    "n_targets": 4,
    "total_columns": 44
  }
}

