{
  "description": "Configuration for synthetic dataset generation parameters",
  
  "dataset": {
    "n_clients": 10,
    "patients_per_client": 1000,
    "random_seed": 42,
    "version": "1.0",
    "description": "Total dataset size = n_clients × patients_per_client = 2000 patients"
  },
  
  "decision_model": {
    "temperature": 1.0,
    "noise_sd": 0.09,
    "description": "Softmax temperature controls decision randomness. noise_sd adds Gaussian noise to scores before softmax."
  },
  
  "output": {
    "formats": ["csv", "xlsx"],
    "output_dir": "../../data/raw/",
    "filename_base": "fed_recommenders_synthetic_dataset",
    "description": "Output files: fed_recommenders_synthetic_dataset.csv and .xlsx"
  },
  
  "metadata": {
    "target_variables": {
      "classifcation": [
        {
          "name": "Risk_AlveolarOsteitis",
          "type": "binary",
          "n_classes": 2,
          "labels": ["No", "Yes"]
        },
        {
          "name": "Risk_SecondaryInfection",
          "type": "binary",
          "n_classes": 2,
          "labels": ["No", "Yes"]
        },
        {
          "name": "Risk_NerveDysesthesia",
          "type": "binary",
          "n_classes": 2,
          "labels": ["No", "Yes"]
        },
        {
          "name": "Risk_Bleeding",
          "type": "binary",
          "n_classes": 2,
          "labels": ["No", "Yes"]
        }
      ]
    },
    "n_features": 26,
    "n_targets": 4,
    "total_columns": 44
  }
}

